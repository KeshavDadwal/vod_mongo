
type User {
  id: ID!
  name: String!
}

type Mutation {
  signup(input: SignupInput!): AuthPayload!
  signin(input: SigninInput!): AuthPayload!
}

input SignupInput {
  username: String!
  email: String!
  password: String!
  displayName: String
}

type PublicUser {
  id: ID!
  username: String!
  email: String!
  displayName: String
  createdAt: String!
}

type AuthPayload {
  token: String!
  user: PublicUser!
}

input SigninInput {
  email: String!
  password: String!
}
